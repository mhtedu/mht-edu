.org-courses-page{min-height:100vh;background-color:#f5f5f5}.stat-card{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;padding:8rpx;background-color:#f9fafb;border-radius:8rpx}.stat-value{font-size:18rpx;font-weight:700;color:#1f2937}.stat-label{font-size:11rpx;color:#6b7280;margin-top:2rpx}.search-icon{position:absolute;left:8rpx;top:50%;-webkit-transform:translateY(-50%);-ms-transform:translateY(-50%);transform:translateY(-50%)}.course-list{height:calc(100vh - 200rpx);padding:12rpx}.course-card{margin-bottom:12rpx}
