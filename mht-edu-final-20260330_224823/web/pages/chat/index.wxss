.chat-page{height:100vh;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;background-color:#f5f5f5}.chat-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;padding:12rpx 16rpx;background-color:#fff;border-bottom:1rpx solid #e5e7eb}.action-bar{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;gap:24rpx;padding:12rpx;background-color:#fff;border-bottom:1rpx solid #e5e7eb}.action-item{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-webkit-align-items:center;-ms-flex-align:center;align-items:center;padding:8rpx 16rpx}.msg-list{-webkit-flex:1;-ms-flex:1;flex:1;padding:16rpx;overflow-y:auto}.msg-item{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:flex-start;-ms-flex-align:start;align-items:flex-start;margin-bottom:16rpx}.msg-item.self{-webkit-flex-direction:row-reverse;-ms-flex-direction:row-reverse;flex-direction:row-reverse}.msg-avatar{width:36rpx;height:36rpx;border-radius:50%;-webkit-flex-shrink:0;-ms-flex-negative:0;flex-shrink:0}.msg-bubble{max-width:70%;padding:10rpx 14rpx;border-radius:16rpx;margin:0 8rpx}.msg-bubble.self{background-color:#2563eb;color:#fff;border-bottom-right-radius:4rpx}.msg-bubble.other{background-color:#fff;border-bottom-left-radius:4rpx}.msg-card{max-width:80%;padding:12rpx;border-radius:12rpx;margin:0 8rpx;background-color:#fff;-webkit-box-shadow:0 1rpx 3rpx rgba(0,0,0,.1);box-shadow:0 1rpx 3rpx rgba(0,0,0,0.10196)}.msg-card.self{background-color:#eff6ff}.msg-card-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center}.input-bar{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;padding:12rpx 16rpx;background-color:#fff;border-top:1rpx solid #e5e7eb;padding-bottom:calc(12rpx + env(safe-area-inset-bottom))}.space-y-2>view+view,.space-y-2>view+text,.space-y-2>text+view,.space-y-2>text+text{margin-top:8rpx}
