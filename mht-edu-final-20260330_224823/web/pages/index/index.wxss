.city-selector{position:fixed;top:0;right:0;bottom:0;left:0;z-index:1000}.city-selector-mask{position:absolute;top:0;right:0;bottom:0;left:0;background-color:rgba(0,0,0,0.50196)}.city-selector-content{position:absolute;bottom:0;left:0;right:0;height:80vh;background-color:#fff;border-radius:16rpx 16rpx 0 0;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column}.city-selector-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;padding:16rpx;border-bottom:1rpx solid #e5e7eb}.city-selector-search{display:-webkit-flex;display:-ms-flexbox;display:flex;padding:12rpx 16rpx;border-bottom:1rpx solid #e5e7eb}.city-selector-section{padding:12rpx 16rpx;border-bottom:1rpx solid #e5e7eb}.city-tags{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:8rpx}.city-tag{display:-webkit-inline-flex;display:-ms-inline-flexbox;display:inline-flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;padding:6rpx 12rpx;background-color:#f3f4f6;border-radius:16rpx;font-size:14rpx;color:#374151}.city-tag.active{background-color:#dbeafe;color:#2563eb}.city-selector-list{-webkit-flex:1;-ms-flex:1;flex:1;overflow-y:auto}.city-letter-header{padding:8rpx 16rpx;background-color:#f3f4f6;font-size:14rpx;color:#6b7280;font-weight:700}.city-list-item{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-align-items:center;-ms-flex-align:center;align-items:center;-webkit-justify-content:space-between;-ms-flex-pack:justify;justify-content:space-between;padding:12rpx 16rpx;border-bottom:1rpx solid #e5e7eb}.city-list-item.active{color:#2563eb;background-color:#f0f9ff}
