# ===========================================
# 棉花糖教育平台 - 环境变量配置
# ===========================================
# 请复制此文件为 .env 并填写实际值

# ===================
# 服务配置
# ===================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ===================
# 数据库配置 (MySQL)
# ===================
DB_HOST=localhost
DB_PORT=3306
DB_USER=mianhuatang
DB_PASSWORD=请修改为你的数据库密码
DB_NAME=mianhuatang_edu

# 数据库连接池
DB_POOL_MIN=2
DB_POOL_MAX=10

# ===================
# JWT 配置
# ===================
JWT_SECRET=请修改为随机字符串至少32位
JWT_EXPIRES_IN=7d

# ===================
# 微信小程序配置
# ===================
WX_APPID=wx46c4d031889bdb3e
WX_SECRET=请在微信公众平台获取AppSecret
WX_MCH_ID=商户号(如需支付功能)
WX_MCH_KEY=商户密钥(如需支付功能)

# ===================
# 文件存储配置
# ===================
# 本地存储路径
UPLOAD_DIR=/var/www/mianhuatang/uploads
# 访问域名
FILE_DOMAIN=https://your-domain.com

# ===================
# 安全配置
# ===================
# 允许跨域域名(多个用逗号分隔)
CORS_ORIGINS=https://your-domain.com

# ===================
# 日志配置
# ===================
LOG_LEVEL=info
LOG_DIR=/var/www/mianhuatang/logs

# ===================
# 业务配置
# ===================
# 分佣比例(百分比)
COMMISSION_LEVEL1=20
COMMISSION_LEVEL2=10
COMMISSION_AGENT=5
COMMISSION_ORG=10

# 会员价格(分)
MEMBERSHIP_MONTH_PRICE=9900
MEMBERSHIP_QUARTER_PRICE=26900
MEMBERSHIP_YEAR_PRICE=89900
