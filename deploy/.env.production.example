# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mht_edu
DB_USER=mht_edu
DB_PASSWORD=请修改为你的数据库密码

# 服务配置
PORT=3000
NODE_ENV=production

# JWT密钥（请生成一个随机字符串，至少32位）
JWT_SECRET=请生成一个随机字符串替换这里

# 微信小程序配置（如果没有可以先留空）
WECHAT_APPID=
WECHAT_SECRET=

# 项目域名（改成你的域名）
PROJECT_DOMAIN=https://你的域名.com

# 对象存储配置（可选，用于文件上传）
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
