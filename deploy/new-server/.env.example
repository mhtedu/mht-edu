# ===================================
# 棉花糖教育平台 - 环境变量配置
# ===================================
# 请根据实际情况修改以下配置

# 服务配置
NODE_ENV=production
PORT=3002

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=mht_edu
DB_PASSWORD=请修改为你的数据库密码
DB_DATABASE=mht_edu

# JWT配置
JWT_SECRET=mht-edu-jwt-secret-2026-change-this
JWT_EXPIRES_IN=7d

# 微信小程序配置
WECHAT_APPID=请填写你的小程序AppID
WECHAT_SECRET=请填写你的小程序Secret

# 平台配置
PLATFORM_NAME=棉花糖教育
PLATFORM_DOMAIN=https://wx.dajiaopei.com

# 可选配置
# REDIS_HOST=localhost
# REDIS_PORT=6379
# OSS_ACCESS_KEY=阿里云OSS密钥
# OSS_ACCESS_SECRET=阿里云OSS密钥
