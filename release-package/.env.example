# ============================================
# 棉花糖教育平台 - 生产环境配置
# ============================================

# 服务配置
NODE_ENV=production
PORT=3002
SERVER_PORT=3002

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=mht_edu
DB_PASSWORD=mht2026edu
DB_DATABASE=mht_edu

# JWT配置（请修改为随机字符串）
JWT_SECRET=mht-edu-jwt-secret-2026-change-this-in-production
JWT_EXPIRES_IN=7d

# 微信小程序配置（请填写真实信息）
WECHAT_APPID=你的小程序AppID
WECHAT_SECRET=你的小程序Secret

# 微信支付配置（请填写真实信息）
WECHAT_MCH_ID=你的商户号
WECHAT_PAY_KEY=你的API密钥32位
WECHAT_NOTIFY_URL=https://mt.dajiaopei.com/api/payment/notify/wechat

# 文件上传配置
UPLOAD_DIR=/www/wwwroot/mht-edu/uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info
LOG_DIR=/www/wwwroot/mht-edu/logs
